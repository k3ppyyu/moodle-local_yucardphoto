{{!
    @template local_yucardphoto/upload

    YU Card Photo — manual upload page for admins.

    Renders the page chrome (title, optional notification, optional current-photo
    preview, and the moodleform). All presentational structure is here so that
    theme designers can override the layout without touching PHP.

    Context variables required:
    * pagetitle         string  Page heading (already formatted/escaped).
    * hasnotice         bool    True when a notice message should be shown.
    * noticesuccess     bool    True when noticeclass should be 'success'.
    * noticemsg         string  Notification body text (already escaped).
    * formhtml          string  Pre-rendered moodleform HTML (triple-mustache, unescaped).

    Example context (json):
    {
        "pagetitle": "YU Card Photo \u2014 Manual Upload",
        "hasnotice": true,
        "noticesuccess": true,
        "noticemsg": "Photo saved successfully for Jane Smith.",
        "formhtml": "<form ...>...</form>"
    }
}}

{{! ── Page heading ─────────────────────────────────────────────────────── }}
<h2 class="mb-3">{{pagetitle}}</h2>

{{! ── Notification (success or error) ────────────────────────────────── }}
{{#hasnotice}}
<div class="alert {{#noticesuccess}}alert-success{{/noticesuccess}}{{^noticesuccess}}alert-danger{{/noticesuccess}} alert-dismissible fade show"
     role="alert">
    {{{noticemsg}}}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
{{/hasnotice}}

{{! ── Upload form (pre-rendered moodleform HTML) ──────────────────────── }}
<div class="ycp-upload-form" data-region="ycp-upload-form">
    {{{formhtml}}}
</div>

{{! ── Helper note for admins ─────────────────────────────────────────── }}
<div class="alert alert-info mt-3 small" role="note">
    {{#str}} choosephoto_help, local_yucardphoto {{/str}}
</div>
