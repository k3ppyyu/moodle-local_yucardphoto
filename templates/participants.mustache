{{!
    @template local_yucardphoto/participants

    YU Card Photo Roster page — responsive, searchable, sortable, paginated
    grid of student photos for a course.

    Classes required:
    * none

    Data attributes required:
    * none

    Context variables required:
    * coursefullname    string  Full name of the course (already formatted/escaped).
    * pagetitle         string  Page <h2> title string (already formatted/escaped).
    * backurl           string  URL back to the Participants (user/index.php) page.
    * backlabel         string  Localised "Back to Participants" label.
    * formaction        string  Form action URL (this page, without query params).
    * courseid          int     Course ID (hidden form field).
    * searchvalue       string  Current search term (HTML-escaped).
    * searchlabel       string  Localised "Search students" label.
    * searchplaceholder string  Localised placeholder text.
    * sortoptions       array   [{value, label, selected}] sort dropdown options.
    * sortlabel         string  Localised "Sort by" label.
    * perPageOptions    array   [{value, label, selected}] per-page dropdown options.
    * perpagelabel      string  Localised "Photos per page" label.
    * searchbtnlabel    string  Localised submit button label.
    * countlabel        string  Localised count string e.g. "45 users".
    * hasstudents       bool    True when the students array is non-empty.
    * students          array   [{firstname, lastname, sisid, email, photourl, alttext}]
    * noresultsmsg      string  Message shown when hasstudents is false.
    * pagingbar         string  Rendered HTML paging bar (from $OUTPUT->render()).

    Example context (json):
    {
        "coursefullname": "Introduction to Computing",
        "pagetitle": "Photo Roster — Introduction to Computing",
        "backurl": "/user/index.php?id=5",
        "backlabel": "Back to Participants",
        "formaction": "/local/yucardphoto/participants.php",
        "courseid": 5,
        "searchvalue": "",
        "searchlabel": "Search students",
        "searchplaceholder": "First name, last name or student ID\u2026",
        "sortoptions": [
            {"value": "lastname",  "label": "Last name",   "selected": true},
            {"value": "firstname", "label": "First name",  "selected": false},
            {"value": "email",     "label": "Email",       "selected": false},
            {"value": "sisid",     "label": "Student ID",  "selected": false}
        ],
        "sortlabel": "Sort by",
        "perPageOptions": [
            {"value": 20,  "label": "4 \u00d7 5 (20 per page)", "selected": true},
            {"value": 100, "label": "All (max 100 per page)",   "selected": false}
        ],
        "perpagelabel": "Photos per page",
        "searchbtnlabel": "Search",
        "countlabel": "3 users",
        "hasstudents": true,
        "students": [
            {
                "firstname": "Jane",
                "lastname": "Smith",
                "sisid": "212345678",
                "email": "jsmith@example.com",
                "photourl": "/pluginfile.php/1/local_yucardphoto/photos/123/212345678.jpg",
                "alttext": "Jane Smith"
            }
        ],
        "noresultsmsg": "",
        "pagingbar": ""
    }
}}

{{! ── Page heading ─────────────────────────────────────────────────────── }}
<div class="ycp-page-header mb-2">
    <h2 class="mb-2">{{pagetitle}}</h2>
    <a href="{{backurl}}" class="btn btn-outline-secondary">
        {{#pix}} t/left, core {{/pix}}
        {{backlabel}}
    </a>
</div>

{{! ── Students section ───────────────────────────────────────────────── }}
<div class="ycp-students-section mt-4">
    <h3 class="mb-3 border-bottom pb-2">{{#str}} students, local_yucardphoto {{/str}}</h3>

    {{! ── Controls bar ────────────────────────────────────────────────── }}
    <form method="get" action="{{formaction}}" class="mb-2"
          data-region="ycp-controls">
        <input type="hidden" name="id" value="{{courseid}}">

        <div class="d-flex align-items-center gap-2 w-100">

            {{! Search — standard Bootstrap 5 input-group prepend pattern }}
            <div style="max-width:22rem; width:100%;">
                <div class="input-group" role="search">
                    <span class="input-group-text" id="ycp-search-addon" aria-hidden="true">
                        {{#pix}} a/search, core {{/pix}}
                    </span>
                    <input type="search"
                           id="ycp-search"
                           name="search"
                           value="{{searchvalue}}"
                           placeholder="{{searchplaceholder}}"
                           class="form-control"
                           autocomplete="off"
                           aria-label="{{searchlabel}}"
                           aria-describedby="ycp-search-addon">
                    <button class="btn btn-outline-secondary btn-clear"
                            id="ycp-clear-search"
                            type="button"
                            style="{{^hassearch}}visibility:hidden;{{/hassearch}}"
                            aria-label="{{#str}} clearsearch, core {{/str}}">
                        {{#pix}} e/cancel, core {{/pix}}
                        <span class="visually-hidden">{{#str}} clearsearch, core {{/str}}</span>
                    </button>
                </div>
            </div>

            {{! Sort by — default form-select size, hugs right }}
            <div class="ms-auto flex-shrink-0">
                <label for="ycp-sort" class="visually-hidden">{{#str}} sortby, local_yucardphoto {{/str}}</label>
                <select id="ycp-sort" name="sort" class="form-select">
                    {{#sortoptions}}
                        {{#placeholder}}
                        <option value="" disabled{{^selected}} selected{{/selected}}>{{label}}</option>
                        {{/placeholder}}
                        {{^placeholder}}
                        <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                        {{/placeholder}}
                    {{/sortoptions}}
                </select>
            </div>

        </div>
    </form>

    {{! ── Result count + missing photo badge (clickable) ─────────────── }}
    <div class="d-flex flex-wrap align-items-center gap-3 mt-2 mb-3">
        <span class="text-muted small">{{countlabel}}</span>
        {{#hasnophoto}}
        <a href="{{nophotourl}}"
           class="badge bg-warning text-dark text-decoration-none"
           title="Sort by missing photos">
            &#9888; {{nophotolabel}}
        </a>
        {{/hasnophoto}}
    </div>

    {{! ── Photo grid ──────────────────────────────────────────────────── }}
    {{#hasstudents}}
    <div class="ycp-photo-grid row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-4 g-3"
         role="list"
         data-region="ycp-grid">
        {{#students}}
        <div class="col" role="listitem">
            <div class="card h-100 text-center ycp-student-card">

                {{! Photo }}
                <div class="card-img-top d-flex justify-content-center align-items-center pt-3 position-relative">
                    <img src="{{photourl}}"
                         alt="{{alttext}}"
                         width="100"
                         height="100"
                         class="rounded-circle ycp-photo{{#nophoto}} ycp-photo-missing{{/nophoto}}"
                         style="object-fit: cover;">
                    {{#nophoto}}
                    <span class="badge bg-warning text-dark position-absolute bottom-0 ycp-missing-badge"
                          title="No photo on file">&#9888; No photo</span>
                    {{/nophoto}}
                </div>

                {{! Student details }}
                <div class="card-body p-2">
                    <p class="mb-1 small"><strong>{{lastname}}, {{firstname}}</strong></p>
                    {{#sisid}}
                        <p class="text-muted small mb-0">{{sisid}}</p>
                    {{/sisid}}
                    <p class="mb-0">
                        <a href="mailto:{{email}}" class="small text-truncate d-block">{{email}}</a>
                    </p>
                </div>

            </div>
        </div>
        {{/students}}
    </div>
    {{/hasstudents}}

    {{^hasstudents}}
    <div class="alert alert-info" role="alert">
        {{noresultsmsg}}
    </div>
    {{/hasstudents}}

    {{! ── Paging bar ───────────────────────────────────────────────────── }}
    {{#pagingbar}}
        {{{pagingbar}}}
    {{/pagingbar}}

    {{! ── Show all / show paged link ─────────────────────────────────── }}
    {{#hasstudents}}
    <div class="mt-2 mb-1">
        <a href="{{showallurl}}" class="small">{{showalllabel}}</a>
    </div>
    {{/hasstudents}}

</div>{{! end .ycp-students-section }}
